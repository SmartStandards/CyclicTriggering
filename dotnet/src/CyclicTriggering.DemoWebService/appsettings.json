{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Warning"
    },
    "SmartStandards": {
      //0=Trace, 1=Debug, 2=Information, 3=Warning, 4=Error, 5=Critical
      "ConsoleLogging": {
        "Enabled": true,
        "DefaultLogLevelFilter": 2
      },
      "FileLogging": {
        "Enabled": true,
        "DefaultLogLevelFilter": 0,
        "TargetFileName": "logs\\{application}-{timestamp:yyyy-MM-dd}.log"
      }
    }
  },
  "AllowedHosts": "*",
  "EnableSwaggerUi": true,
  "ProdMode": false,
  "BaseUrl": "/"
}
